# Supabase 配置
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key

# 蓝兔支付配置（扫码支付）
VITE_LANTUZ_MCH_ID=your_lantuz_mch_id
VITE_LANTUZ_API_KEY=your_lantuz_api_key
VITE_LANTUZ_API_URL=https://api.ltzf.cn/api
VITE_LANTUZ_NOTIFY_URL=https://your-domain.com/api/payment/callback

# 应用配置
VITE_APP_TITLE="网盘资源发布系统"
VITE_APP_DESCRIPTION="一个基于Vue3和Supabase的网盘资源发布系统"
VITE_APP_BASE_PATH=/

# 存储桶配置
VITE_STORAGE_AVATARS_BUCKET=avatars
VITE_STORAGE_RESOURCE_COVERS_BUCKET=resource-covers

# 开发环境配置
VITE_APP_ENV=development
VITE_APP_DEBUG=true